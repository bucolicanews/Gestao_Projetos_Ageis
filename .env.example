# ============================================================
# Variáveis de ambiente — copie para .env e preencha
# ============================================================

# URL do projeto Supabase (cloud OU local: http://127.0.0.1:54321)
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# IMPORTANTE: o módulo @nuxtjs/supabase usa SUPABASE_KEY (não _ANON_KEY)
SUPABASE_KEY=sua_chave_anon_aqui

# Mantemos também SUPABASE_ANON_KEY para uso direto em scripts/Edge Functions
SUPABASE_ANON_KEY=sua_chave_anon_aqui

# Apenas para scripts servidor / seed (NUNCA exponha no front)
SUPABASE_SERVICE_ROLE_KEY=apenas_para_scripts_servidor
